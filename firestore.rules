rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'matheusrs180@gmail.com' && request.auth.token.email_verified == true
      );
    }

    // Identity Collections (codes, families, guests)
    match /codes/{code} {
      allow get: if true;
      allow list, write: if isAdmin();
    }

    match /families/{familyId} {
      allow get: if true;
      allow list, write: if isAdmin();
    }

    match /guests/{guestId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    // RSVP Validation
    function isValidRSVP(data) {
      return data.familyId is string && isValidId(data.familyId) &&
             data.confirmedBy is string && isValidId(data.confirmedBy) &&
             data.attendees is list &&
             data.adults is int && data.adults >= 0 &&
             data.childrenCount is int && data.childrenCount >= 0 &&
             data.createdAt == request.time;
    }

    match /rsvps/{rsvpId} {
      allow create: if isSignedIn() && isValidRSVP(incoming());
      allow read: if isAdmin();
      allow list: if isAdmin();
    }

    // Gift Validation
    function isValidGift(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             (data.isBought == null || data.isBought is bool);
    }

    match /gifts/{giftId} {
      allow read: if true;
      allow list: if true;
      allow write: if isAdmin() && isValidGift(incoming());
    }

    // Contribution Validation
    function isValidContribution(data) {
      return data.amount is number && data.amount > 0 &&
             data.donorName is string && data.donorName.size() <= 200 &&
             data.status in ['pending', 'completed'] &&
             data.createdAt == request.time;
    }

    match /contributions/{contribId} {
      allow create: if isValidContribution(incoming());
      allow read: if isAdmin();
      allow list: if isAdmin();
    }

    // TieBid Validation (Gravata do Noivo)
    // Cliente cria apenas 'pending'; promocao de status e exclusiva do servidor (Admin SDK).
    function isValidTieBid(data) {
      return data.amount is number && data.amount > 0 &&
             data.status == 'pending' &&
             data.createdAt == request.time &&
             (data.message == null || (data.message is string && data.message.size() <= 500)) &&
             (!('familyId' in data) || isValidId(data.familyId)) &&
             (!('guestId' in data) || isValidId(data.guestId));
    }

    match /tieBids/{bidId} {
      allow create: if isSignedIn() && isValidTieBid(incoming());
      allow update: if isAdmin();
      // Leaderboard publico real so apos leaderboards/* derivados (SPEC-GRAVATA completa).
      allow read, list: if isAdmin();
    }
  }
}
